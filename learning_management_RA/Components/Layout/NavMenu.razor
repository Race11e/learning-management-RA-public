@rendermode InteractiveServer
@inject NavigationManager Nav

<aside class="sidebar @(isCollapsed ? "collapsed" : "")">
    <div class="sidebar-header">
        @if (!isCollapsed) { <h3>LMS</h3> }
        <button class="toggle-btn" @onclick="ToggleSidebar">☰</button>
    </div>
    
    @if (!isCollapsed)
    {
        <nav class="nav-menu">
            <ul>
                <li><a href="/">Exit to Role Selection</a></li>
            </ul>
        </nav>
    }
</aside>

@code {
    private bool isCollapsed = false;
    private void ToggleSidebar() => isCollapsed = !isCollapsed;
}

<style>
    /* Add the sidebar CSS styles from the previous layout here */
    .sidebar { width: 250px; transition: width 0.3s; background: #2c3e50; color: white; padding: 1rem; height: 100%; }
    .sidebar.collapsed { width: 60px; padding: 0.5rem; }
    .sidebar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .toggle-btn { background: none; border: 1px solid white; color: white; cursor: pointer; padding: 5px 10px; }
    .nav-menu ul { list-style: none; padding: 0; }
    .nav-menu li { margin-bottom: 1rem; }
    .nav-menu a { color: #ecf0f1; text-decoration: none; }
</style>