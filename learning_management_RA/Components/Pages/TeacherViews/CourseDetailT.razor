    // For creating new student; adds student to course and global student list
    private void CreateAndEnrollStudent()
    {
        studentErrorMessage = "";
        if (string.IsNullOrWhiteSpace(newStudentName) && string.IsNullOrWhiteSpace(newStudentCode))
        {
            studentErrorMessage = "Name and Code required.";
            return;
        }

        if (course != null)
        {
            var existingStudent = StudentService.Students.FirstOrDefault(s => s.Code.Equals(newStudentCode.Trim(), StringComparison.InvariantCultureIgnoreCase));
            if (existingStudent != null)
            {
                if (course.Roster.Any(r => r.Id == existingStudent.Id))
                {
                    studentErrorMessage = "A student with this  code already exists.";
                }
                else
                {
                    course.Roster.Add(existingStudent);
                    ResetStudentForm();
                }
            }
            else
            {
                int newId = StudentService.Students.Any() ? StudentService.Students.Max(g => g.Id) + 1 : 1;

                var newStudent = new Student
                {
                    Id = newId,
                    Name = newStudentName.Trim(),
                    Classification = newStudentClass,
                    Code = newStudentCode.Trim()
                };
                
                StudentService.Students.Add(newStudent);
                course.Roster.Add(newStudent);
                ResetStudentForm();
            }
        }
    }

    private void ResetStudentForm()
    {
        newStudentName = "";
        newStudentCode = "";
        studentErrorMessage = "";
    }

    // Assignment CSV Export/Import ====================================================================
    private async Task ExportAssignmentsCsv()
    {
        if (course == null || !course.Assignments.Any()) return;
        var csvBuilder = new System.Text.StringBuilder();
        csvBuilder.AppendLine("Name,Description,PointsAvailable,DueDate,GroupId,IsQuiz,QuizQuestion");
        foreach (var a in course.Assignments)
        {
            var desc = a.Description?.Replace(',', ' ') ?? "";
            var quest = a.QuizQuestion?.Replace(",", " ") ?? "";
            
            csvBuilder.AppendLine($"{a.Name},{desc},{a.AvailablePoints},{a.DueDate:yyyy-MM-dd},{a.AssignmentGroupId},{a.IsQuiz},{quest}");
        }
        var fileBytes = System.Text.Encoding.UTF8.GetBytes(csvBuilder.ToString());
        var fileName = $"{course.Code}_Assignments.csv";
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(fileBytes));
    }

    // read assignment import csv file and hold in memory
    private async Task HandleAssignmentFileSelected(InputFileChangeEventArgs e)
    {
        tempImportAssignments.Clear();
        assignmentImportError = null;

        try
        {
            using var stream = e.File.OpenReadStream();
            using var reader = new System.IO.StreamReader(stream);
            var header = await reader.ReadLineAsync();

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (string.IsNullOrWhiteSpace(line)) continue;

                var values = line.Split(',');
                if (values.Length >= 7)
                {
                    int.TryParse(values[2], out int points);
                    DateTime.TryParse(values[3], out DateTime dueDate);
                    int.TryParse(values[4], out int groupId);
                    bool.TryParse(values[5], out bool isQuiz);

                    tempImportAssignments.Add(new Assignment
                    {
                        Name = values[0].Trim(),
                        Description = values[1].Trim(),
                        AvailablePoints = points,
                        DueDate = dueDate == default ? DateTime.Now.AddDays(7) : dueDate,
                        AssignmentGroupId = groupId,
                        IsQuiz = isQuiz,
                        QuizQuestion = values[6].Trim(),
                        Submissions = new List<Submission>()
                    });
                }
            }

            if (!tempImportAssignments.Any())
            {
                assignmentImportError = "";
            }
        }
        catch (Exception ex)
        {
            assignmentImportError = ""; // Issue with error message on success as well
        }
    }

    // Commit assignment cvs import to course
    private void ConfirmAssignmentImport()
    {
        if (course != null && tempImportAssignments.Any())
        {
            int startingId = course.Assignments.Any() ? course.Assignments.Max(g => g.Id) + 1 : 1;

            foreach (var newAssignment in tempImportAssignments)
            {
                newAssignment.Id = startingId++;
                course.Assignments.Add(newAssignment);
            }
            tempImportAssignments.Clear();
            showSuccess = true;
        }
    }
    
    // cancel import
    private void CancelAssignmentImport()
    {
        tempImportAssignments.Clear();
        assignmentImportError = null;
    }
    
    // CSV export gradebook
    private async Task ExportGradebookCsv()
    {
        if (course == null || !course.Roster.Any()) return;
        
        var csvBuilder = new System.Text.StringBuilder();

        csvBuilder.Append("StudentId,Name,");
        foreach (var a in course.Assignments)
        {
            csvBuilder.Append($"{a.Name} (/{a.AvailablePoints}),");
        }
        csvBuilder.Append("Current Grade %");

        foreach (var student in course.Roster)
        {
            csvBuilder.Append($"{student.Id},{student.Name},");

            double earned = 0;
            double possible = 0;

            foreach (var a in course.Assignments)
            {
                var sub = a.Submissions.FirstOrDefault(s => s.StudentId == student.Id);
                string scoreString = sub?.Grade?.ToString() ?? "0";
                csvBuilder.Append($"{scoreString},");

                if (sub != null && sub.Grade.HasValue)
                {
                    earned += sub.Grade.Value;
                    possible += a.AvailablePoints;
                } 
            }

            double totalPercent = possible == 0 ? 100.0 : (earned / possible) * 100;
            csvBuilder.AppendLine($"{totalPercent}:0.00");
        }
        var fileBytes = System.Text.Encoding.UTF8.GetBytes(csvBuilder.ToString());
        var fileName = $"{course.Code}_Gradebook.csv";
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(fileBytes));
    }

    
    
